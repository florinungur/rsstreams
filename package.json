{
    "name": "rsstreams",
    "version": "0.1.0",
    "private": true,
    "description": "Find every RSS/Atom feed for the YouTube page you're on.",
    "homepage": "https://github.com/florinungur/rsstreams#readme",
    "bugs": "https://github.com/florinungur/rsstreams/issues",
    "license": "MIT",
    "author": "Florin Ungur <florin@florinungur.com>",
    "repository": {
        "type": "git",
        "url": "https://github.com/florinungur/rsstreams.git"
    },
    "type": "module",
    "scripts": {
        "dev": "wxt -b firefox",
        "build": "wxt build -b firefox",
        "zip": "wxt zip -b firefox",
        "compile": "tsc --noEmit",
        "compile:e2e": "tsc -p e2e/tsconfig.json",
        "lint": "oxlint",
        "format": "oxfmt",
        "format:check": "oxfmt --check",
        "test": "vitest",
        "test:run": "vitest run --coverage",
        "test:canary": "vitest run --config vitest.canary.config.ts",
        "build:e2e": "wxt build -b firefox --mode e2e",
        "e2e": "pnpm build:e2e && node --test e2e/*.test.ts",
        "wxt:prepare": "wxt prepare"
    },
    "devDependencies": {
        "@types/firefox-webext-browser": "^143.0.0",
        "@types/node": "^25.9.1",
        "@types/selenium-webdriver": "^4.35.5",
        "@vitest/coverage-v8": "^4.1.7",
        "jsdom": "^29.1.1",
        "oxfmt": "^0.51.0",
        "oxlint": "^1.66.0",
        "selenium-webdriver": "4.44.0",
        "typescript": "^5.9.3",
        "vitest": "^4.1.7",
        "wxt": "0.20.26"
    },
    "packageManager": "pnpm@11.3.0"
}
